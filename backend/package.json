{
  "name": "@mike-games/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile knexfile.ts",
    "seed": "knex seed:run --knexfile knexfile.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/session": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "@mike-games/shared": "*",
    "adm-zip": "^0.5.16",
    "argon2": "^0.41.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "knex": "^3.1.0",
    "nanoid": "^5.0.0",
    "otpauth": "^9.5.0",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "semver": "^7.6.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/connect-pg-simple": "^7.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/semver": "^7.5.0",
    "tsx": "^4.19.0"
  }
}
